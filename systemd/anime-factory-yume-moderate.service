After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/ratelhhhh/anime-meme-factory-go
ExecStart=/home/ratelhhhh/anime-meme-factory-go/factory --config config.yume.json moderate-bot
